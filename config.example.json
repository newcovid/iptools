{
  "language": "Zh",
  "scan_concurrency": 50,
  "keybindings": {
    "back": ["Esc"],
    "confirm": ["Enter"],
    "down": ["Down", "j"],
    "edit": ["e"],
    "help": ["F1"],
    "left": ["Left", "h"],
    "next_tab": ["Tab"],
    "prev_tab": ["Shift+Tab"],
    "quit": ["Ctrl+c", "Ctrl+q"],
    "history": ["Ctrl+r"],
    "refresh": ["r"],
    "right": ["Right", "l"],
    "stop": ["s"],
    "toggle": ["Space"],
    "toggle_language": ["Ctrl+l"],
    "up": ["Up", "k"]
  },
  "public_ip": {
    "endpoints": [
      { "url": "https://api.ip.sb/geoip", "kind": "ipsb" },
      { "url": "https://ipinfo.io/json", "kind": "ipinfo" }
    ],
    "use_system_proxy": true
  }
}
